# ── Local ──────────────────────────────────────────────────────────────
# cp .env.local.example .env.local
# Pega tu connection string desde Neon → Dashboard → Connect

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Opcional en local (en Vercel se detecta solo si no la defines)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Vercel (Project → Settings → Environment Variables) ───────────────
# Obligatoria:
#   DATABASE_URL = connection string de Neon
#   Usa el string "Pooled" recomendado para serverless (Neon → Connect).
#   Marca: Production, Preview y Development.
#
# Opcional (si quieres un dominio fijo en enlaces de invitación):
#   NEXT_PUBLIC_APP_URL = https://tu-dominio.vercel.app
#
# Sin NEXT_PUBLIC_APP_URL, Vercel usa VERCEL_URL automáticamente.
#
# Después del primer deploy, aplica el schema una vez desde tu máquina:
#   DATABASE_URL="postgresql://..." npm run db:setup
